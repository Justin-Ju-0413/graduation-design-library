# Fig 3.3: PE Microarchitecture — calibrated against AI reference
# Processing Element (PE) internal datapath

direction: down

# ── INPUTS ──
"W (INT8)"
"D (INT8)"

# ── DATAPATH: Multiplier → Accumulator → ReLU ──

"8b × 8b\nSigned Multiplier" {
  style.fill: "#FFF8E1"
  style.stroke: "#F57C00"
  style.stroke-width: 2
}

"INT32 Accumulator\nacc ← acc + sign_extend(P)" {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

"ReLU\nif acc < 0 → output 0\nelse → output acc" {
  style.fill: "#FCE4EC"
  style.stroke: "#E91E63"
  style.stroke-width: 2
}

# ── OUTPUT ──
"Result (INT32)" {
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
}

# ── CONTROL SIGNALS ──
"acc_clr" {
  style.fill: "#F5F5F5"
  style.stroke: "#666"
  style.stroke-width: 1
}
"en" {
  style.fill: "#F5F5F5"
  style.stroke: "#666"
  style.stroke-width: 1
}

# ── DATA FLOW ──
"W (INT8)" -> "8b × 8b\nSigned Multiplier"
"D (INT8)" -> "8b × 8b\nSigned Multiplier"
"8b × 8b\nSigned Multiplier" -> "INT32 Accumulator\nacc ← acc + sign_extend(P)": "P (INT16)"
"INT32 Accumulator\nacc ← acc + sign_extend(P)" -> "ReLU\nif acc < 0 → output 0\nelse → output acc"
"ReLU\nif acc < 0 → output 0\nelse → output acc" -> "Result (INT32)"

# ── FEEDBACK: ReLU → Accumulator ──
"ReLU\nif acc < 0 → output 0\nelse → output acc" -> "INT32 Accumulator\nacc ← acc + sign_extend(P)": "accumulate"

# ── CONTROL ──
"acc_clr" -> "INT32 Accumulator\nacc ← acc + sign_extend(P)"
"en" -> "INT32 Accumulator\nacc ← acc + sign_extend(P)"
